{
  "manifest_version": 3,
  "name": "Rekolto Browser Relay",
  "version": "0.1.0",
  "description": "Bridge between Rekolto bot and the browser for fetching JS-rendered pages",
  "permissions": ["debugger", "tabs", "activeTab", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rekolto Relay"
  }
}
